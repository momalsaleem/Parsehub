# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!

# ─── ParseHub API (direct API access for run/analytics routes) ───────────────
PARSEHUB_API_KEY=t4oahuH8vOki
PARSEHUB_BASE_URL=https://www.parsehub.com/api/v2

# ─── Backend Proxy URL (SERVER-SIDE ONLY — never expose to browser) ──────────
# This is used by Next.js API route handlers to proxy requests to Flask.
# Local development:
BACKEND_API_URL=http://localhost:5000
# Production (Railway) — set this in Railway → frontend service → Variables:
# BACKEND_API_URL=https://parsehub-backend-production.up.railway.app

# ─── Optional: Internal API key for Flask backend ────────────────────────────
BACKEND_API_KEY=t_hmXetfMCq3

# ─── DEPRECATED — no longer needed (browser now calls same-origin /api/*) ────
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000   <-- remove from Railway too

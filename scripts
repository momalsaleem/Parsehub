#!/usr/bin/env python
"""
Add metadata for project tsTA0g3nsdNd with total_pages = 195
"""
from datetime import datetime
from backend.database import ParseHubDatabase
import sys
sys.path.insert(
    0, 'd:\\Paramount Intelligence\\ParseHub\\Updated POC\\Parsehub_project')


db = ParseHubDatabase()
db.connect()
cursor = db.conn.cursor()

# Find the project
cursor.execute(
    'SELECT id, token, title FROM projects WHERE token = ?', ('tsTA0g3nsdNd',))
project = cursor.fetchone()

if project:
    project_id, token, title = project
    print(f"Found project: {title} (ID: {project_id}, Token: {token})")

    # Check if metadata already exists
    cursor.execute('SELECT id FROM metadata WHERE project_token = ?', (token,))
    existing = cursor.fetchone()

    if existing:
        print(f"Metadata already exists with ID: {existing[0]}")
    else:
        # Insert metadata record
        print("\nInserting metadata record...")
        cursor.execute('''
            INSERT INTO metadata (
                personal_project_id, 
                project_id, 
                project_token, 
                project_name, 
                total_pages,
                created_date,
                updated_date,
                status
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            token,  # personal_project_id
            project_id,  # project_id
            token,  # project_token
            title,  # project_name
            195,  # total_pages
            datetime.now().isoformat(),  # created_date
            datetime.now().isoformat(),  # updated_date
            'active'  # status
        ))

        db.conn.commit()

        # Verify it was inserted
        cursor.execute(
            'SELECT id, project_token, project_name, total_pages FROM metadata WHERE project_token = ?', (token,))
        result = cursor.fetchone()
        if result:
            print(f"✓ Metadata created successfully:")
            print(f"  ID: {result[0]}")
            print(f"  Token: {result[1]}")
            print(f"  Name: {result[2]}")
            print(f"  Pages: {result[3]}")
        else:
            print("✗ Failed to create metadata")
else:
    print(f"Project not found: tsTA0g3nsdNd")

db.disconnect()
